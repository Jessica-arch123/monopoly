<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PharmaPoly: Chemistry Edition</title>
    <style>
        :root { --primary: #6c5ce7; --accent: #00b894; --bg: #f0f2f5; --gold: #fdcb6e; --pink: #fd79a8; }
        body { font-family: 'Poppins', sans-serif; background: var(--bg); display: flex; justify-content: center; padding: 10px; }
        .game-container { background: white; width: 100%; max-width: 500px; border-radius: 30px; box-shadow: 0 20px 50px rgba(0,0,0,0.1); overflow: hidden; position: relative; border: 5px solid #333; }
        
        /* The Board Track */
        .board-track { 
            display: grid; 
            grid-template-columns: repeat(4, 1fr); 
            grid-template-rows: repeat(4, 1fr); 
            gap: 5px; 
            padding: 15px; 
            background: #2d3436; 
            height: 350px;
        }
        .tile { 
            background: white; 
            border-radius: 8px; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            font-size: 0.8rem; 
            font-weight: bold; 
            position: relative; 
            color: #333;
            text-align: center;
            border-bottom: 4px solid #ddd;
        }
        .tile-active { border-color: var(--primary); background: #efedff; transform: scale(1.05); z-index: 5; }
        .tile-start { background: var(--accent); color: white; }
        
        /* Mascot Piece */
        #playerPiece { 
            position: absolute; 
            font-size: 2rem; 
            transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            z-index: 10;
            filter: drop-shadow(0 5px 5px rgba(0,0,0,0.2));
        }

        .center-ui { padding: 20px; text-align: center; background: #fff; }
        .stats-bar { display: flex; justify-content: space-around; background: #f9f9f9; padding: 10px; font-weight: 800; border-top: 2px solid #eee; }
        
        .question-overlay { 
            position: fixed; top: 0; left: 0; width: 100%; height: 100%; 
            background: rgba(0,0,0,0.8); display: none; align-items: center; justify-content: center; z-index: 100; padding: 20px; box-sizing: border-box;
        }
        .q-card { background: white; padding: 25px; border-radius: 20px; width: 100%; max-width: 400px; text-align: center; }

        .btn { width: 100%; padding: 12px; border: none; border-radius: 12px; color: white; font-weight: bold; cursor: pointer; margin-bottom: 8px; }
        .btn-roll { background: var(--primary); font-size: 1.2rem; box-shadow: 0 5px 0 #4834d4; }
        .btn-mcq { background: #f1f2f6; color: var(--primary); border: 2px solid var(--primary); }
        
        .badge { font-size: 0.7rem; background: var(--gold); padding: 2px 5px; border-radius: 5px; position: absolute; top: -5px; }
        sub, sup { font-size: 0.7em; }
    </style>
</head>
<body>

<div class="game-container">
    <div class="board-track" id="board">
        <div class="tile tile-start" id="t0">GO</div>
        <div class="tile" id="t1">SO<sub>2</sub></div>
        <div class="tile" id="t2">NaOH</div>
        <div class="tile" id="t3">CHANCE</div>
        <div class="tile" id="t11">Ag<sup>+</sup></div>
        <div style="grid-column: span 2; grid-row: span 2; display:flex; align-items:center; justify-content:center;">
             <img src="https://cdn-icons-png.flaticon.com/512/3022/3022607.png" width="80" style="opacity:0.2">
        </div>
        <div class="tile" id="t4">PCl<sub>5</sub></div>
        <div class="tile" id="t10">buffer</div>
        <div class="tile" id="t5">Ni(CO)<sub>4</sub></div>
        <div class="tile" id="t9">O<sub>2</sub><sup>+</sup></div>
        <div class="tile" id="t8">SF<sub>6</sub></div>
        <div class="tile" id="t7">CHANCE</div>
        <div class="tile" id="t6">KOH</div>
        
        <div id="playerPiece">🐱</div>
    </div>

    <div class="center-ui">
        <h3 id="tileTitle">Welcome to PharmaPoly!</h3>
        <p id="tileDesc" style="font-size: 0.8rem; color: #666;">Roll the dice to move your mascot.</p>
        <button class="btn btn-roll" onclick="rollDice()">🎲 ROLL DICE</button>
        <div id="feedback" style="font-weight:bold; height: 20px;"></div>
    </div>

    <div class="stats-bar">
        <span>💰 BALANCE: <span id="score">0</span> pts</span>
        <span>🎓 RANK: <span id="rank">Initiate</span></span>
    </div>
</div>

<div class="question-overlay" id="qOverlay">
    <div class="q-card">
        <h4 id="qType" style="color:var(--primary); margin:0;">RESEARCH TASK</h4>
        <p id="qText" style="margin: 20px 0; font-weight: 500;"></p>
        <div id="optionsArea"></div>
        <div id="calcArea" style="display:none">
            <input type="number" id="calcInput" style="width:100%; padding:10px; border-radius:10px; border:1px solid #ddd; text-align:center;">
            <button class="btn btn-roll" style="margin-top:10px" onclick="checkCalc()">SUBMIT DATA</button>
        </div>
    </div>
</div>

<script>
    const boardItems = [
        { name: "GO", type: "start" },
        { name: "SO2 Lab", lvl: 1, type: "q" },
        { name: "Acid Unit", lvl: 1, type: "q" },
        { name: "Grant Chance", type: "chance" },
        { name: "Ni-Carbonyl", lvl: 2, type: "q" },
        { name: "PCl5 Orbit", lvl: 2, type: "q" },
        { name: "KOH Station", lvl: 2, type: "q" },
        { name: "Scholarship", type: "chance" },
        { name: "SF6 Octa", lvl: 2, type: "q" },
        { name: "O2 Cation", lvl: 3, type: "q" },
        { name: "Buffer Zone", lvl: 3, type: "q" },
        { name: "Ag-Solubility", lvl: 2, type: "q" }
    ];

    const questions = [
        { lvl: 1, isMCQ: true, text: "Geometry of SO<sub>2</sub>?", options: ["Linear", "Bent", "T-shaped", "Trigonal"], correct: "Bent" },
        { lvl: 1, text: "NaOH (MW:40) for 1.5L of 0.1M? (grams)", calc: () => 6.00 },
        { lvl: 2, isMCQ: true, text: "Hybridisation of P in PCl<sub>5</sub>?", options: ["sp<sup>3</sup>", "sp<sup>3</sup>d", "sp<sup>3</sup>d<sup>2</sup>", "dsp<sup>2</sup>"], correct: "sp<sup>3</sup>d" },
        { lvl: 3, isMCQ: true, text: "Bond order for O<sub>2</sub><sup>+</sup>?", options: ["1.5", "2.0", "2.5", "3.0"], correct: "2.5" },
        { lvl: 3, text: "Buffer: [A<sup>-</sup>]=0.5, [HA]=0.05, pK<sub>a</sub>=3.8. pH?", calc: () => 4.80 }
    ];

    let state = { pos: 0, score: 0, pet: '🐱' };

    function rollDice() {
        const roll = Math.floor(Math.random() * 3) + 1; // 1-3 steps
        movePlayer(roll);
    }

    function movePlayer(steps) {
        state.pos = (state.pos + steps) % 12;
        updatePiece();
        setTimeout(() => handleLanding(), 600);
    }

    function updatePiece() {
        const tile = document.getElementById('t' + state.pos);
        const rect = tile.getBoundingClientRect();
        const boardRect = document.getElementById('board').getBoundingClientRect();
        const piece = document.getElementById('playerPiece');
        
        piece.style.left = (tile.offsetLeft + 10) + 'px';
        piece.style.top = (tile.offsetTop + 10) + 'px';
        
        document.querySelectorAll('.tile').forEach(t => t.classList.remove('tile-active'));
        tile.classList.add('tile-active');
    }

    function handleLanding() {
        const land = boardItems[state.pos];
        if (land.type === "start") {
            state.score += 100;
            document.getElementById('feedback').innerText = "Passed GO! Collected 100 PTS 🎓";
            sync();
        } else if (land.type === "chance") {
            const win = Math.random() > 0.5;
            state.score += win ? 50 : -30;
            document.getElementById('feedback').innerText = win ? "Research Grant! +50 PTS" : "Lab Spillage... -30 PTS";
            sync();
        } else {
            showQuestion(land.lvl);
        }
    }

    function showQuestion(lvl) {
        const pool = questions.filter(q => q.lvl === lvl);
        const q = pool[Math.floor(Math.random() * pool.length)];
        window.currentQ = q;
        
        document.getElementById('qText').innerHTML = q.text;
        document.getElementById('qOverlay').style.display = 'flex';
        
        const optArea = document.getElementById('optionsArea');
        const calcArea = document.getElementById('calcArea');
        optArea.innerHTML = '';
        
        if (q.isMCQ) {
            calcArea.style.display = 'none';
            optArea.style.display = 'block';
            q.options.forEach(opt => {
                const b = document.createElement('button');
                b.className = "btn btn-mcq"; b.innerHTML = opt;
                b.onclick = () => processAnswer(opt === q.correct);
                optArea.appendChild(b);
            });
        } else {
            optArea.style.display = 'none';
            calcArea.style.display = 'block';
        }
    }

    function processAnswer(isCorrect) {
        if (isCorrect) {
            state.score += 50;
            document.getElementById('feedback').innerText = "Correct! Property acquired. 🧪";
        } else {
            state.score -= 20;
            document.getElementById('feedback').innerText = "Contamination! -20 PTS 💀";
        }
        document.getElementById('qOverlay').style.display = 'none';
        sync();
    }

    function checkCalc() {
        const val = parseFloat(document.getElementById('calcInput').value);
        processAnswer(Math.abs(val - window.currentQ.calc()) < 0.1);
        document.getElementById('calcInput').value = '';
    }

    function sync() {
        document.getElementById('score').innerText = state.score;
        let r = "Initiate";
        if(state.score > 200) r = "Researcher";
        if(state.score > 500) r = "Lab Manager";
        document.getElementById('rank').innerText = r;
    }

    // Initialize piece position
    updatePiece();
</script>
</body>
</html>
